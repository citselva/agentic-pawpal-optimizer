%% ============================================================
%% Diagram 1 — System Architecture Overview
%% Main components and their relationships
%% ============================================================

graph TB
    subgraph UI["UI Layer (Streamlit)"]
        CHAT["Chat Assistant\n(NL input)"]
        GANTT["Gantt Chart\n(schedule view)"]
        SIDEBAR["Sidebar\n(pet / task admin)"]
    end

    subgraph AGENT["Agent Layer"]
        ORCH["Orchestrator\n(coordinates all LLM calls)"]
        PARSER["NL Parser\nClaude Haiku 4.5\n(text → structured task)"]
        REACT["ReAct Loop\nClaude Sonnet 4.6\n(conflict resolution, ≤5 steps)"]
        GUARD["Guardrail\n(post-loop validator)"]
        TOOLS["Tool Registry\n(10 callable tools)"]
    end

    subgraph CORE["Core Scheduling Layer"]
        SCHED["Scheduler\n(two-phase deterministic)"]
        CONFLICT["Conflict Detector\n(sweep-line algorithm)"]
    end

    subgraph DATA["Data Layer"]
        OWNER["Owner"]
        PET["Pet"]
        TASK["Task"]
        RESULT["ScheduleResult"]
    end

    subgraph AUDIT["Audit & Observability"]
        TRACE["TraceStep Log\n(Thought → Action → Observation)"]
        JSONL["Guardrail JSONL\n(append-only violation log)"]
        METRICS["RunMetrics\n(latency, token usage)"]
    end

    CHAT -->|free-form text| ORCH
    SIDEBAR -->|structured form data| ORCH
    ORCH --> PARSER
    ORCH --> REACT
    ORCH --> GUARD
    REACT --> TOOLS
    TOOLS --> CONFLICT
    TOOLS --> SCHED
    SCHED --> CONFLICT
    SCHED --> RESULT
    RESULT --> GANTT
    GUARD --> JSONL
    REACT --> TRACE
    ORCH --> METRICS
    OWNER --> PET --> TASK
    SCHED --> OWNER


%% ============================================================
%% Diagram 2 — Data Flow (Input → Process → Output)
%% ============================================================

---

flowchart LR
    U(["👤 Owner / User"])

    subgraph INPUT["Input"]
        NL["Natural-language\ncare request"]
        FORM["Structured form\n(pet name, duration,\npriority, due date)"]
    end

    subgraph PARSE["Parse & Validate"]
        HAIKU["NL Parser\nHaiku 4.5\nextract Task fields"]
        FILTER["Temporal Filter\ndue_date ≤ today\n& not completed"]
    end

    subgraph SCHEDULE["Schedule"]
        P1["Phase 1\nRequired tasks\n(sorted by priority)"]
        P2["Phase 2\nOptional tasks\nShortest-Job-First"]
        CD["Conflict Detector\noverlapping windows?"]
    end

    subgraph RESOLVE["Resolve (if conflicts)"]
        SONNET["ReAct Agent\nSonnet 4.6\nreschedule_task calls"]
        GRD["Guardrail Check\nrestore dropped\nrequired tasks"]
    end

    subgraph OUTPUT["Output"]
        GANT["Gantt Chart\nvisualization"]
        SKIP["Skipped tasks\nlist (capacity)"]
        LOG["Audit trail\n(reasoning trace\n+ violation log)"]
    end

    U --> NL & FORM
    NL --> HAIKU --> FILTER
    FORM --> FILTER
    FILTER --> P1 --> P2 --> CD
    CD -->|"no conflicts"| GANT
    CD -->|"conflicts found"| SONNET --> GRD --> GANT
    GRD --> LOG
    P2 --> SKIP
    SONNET --> LOG


%% ============================================================
%% Diagram 3 — Human-in-the-Loop & Testing Checkpoints
%% ============================================================

---

flowchart TB
    subgraph HUMAN["Human Checkpoints"]
        direction LR
        H1["H1 · Task Entry\nOwner describes care\nin plain language or form"]
        H2["H2 · Schedule Review\nOwner inspects Gantt\nbefore confirming"]
        H3["H3 · Mark Complete\nOwner taps task\nto toggle done"]
        H4["H4 · Audit Review\nOwner reads guardrail\nviolation log\n(optional)"]
    end

    subgraph AI["AI Processing (automated)"]
        A1["NL Parsing\n(Haiku 4.5)"]
        A2["Two-phase Scheduling"]
        A3["ReAct Conflict\nResolution (Sonnet 4.6)"]
        A4["Guardrail Validation"]
    end

    subgraph TEST["Automated Test Checkpoints"]
        direction LR
        T1["T1 · Unit Tests\ntool schemas, data models\n(~30 tests)"]
        T2["T2 · Integration Tests\nNL parsing accuracy\nReAct resolution rounds"]
        T3["T3 · Guardrail Tests\nrequired-task restoration\naudit log correctness"]
        T4["T4 · End-to-End Tests\nfull owner workflow\nfrom input to schedule"]
    end

    H1 -->|input| A1
    A1 --> A2
    A2 -->|conflicts?| A3
    A3 --> A4
    A4 -->|corrected schedule| H2
    H2 -->|satisfied| H3
    A4 -->|violations logged| H4

    T1 -.->|validates| A1
    T1 -.->|validates| A2
    T2 -.->|validates| A1
    T2 -.->|validates| A3
    T3 -.->|validates| A4
    T4 -.->|validates| H1 & H2 & H3
