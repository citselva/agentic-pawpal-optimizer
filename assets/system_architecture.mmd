flowchart TD
    %% ── CLASS DEFINITIONS ───────────────────────────────────────────────────
    classDef input     fill:#101B35,stroke:#1A2E55,color:#FFFFFF,font-weight:bold
    classDef process   fill:#2EC4B6,stroke:#1EA89B,color:#FFFFFF
    classDef llm       fill:#FF6B35,stroke:#E8531E,color:#FFFFFF,font-weight:bold
    classDef guardrail fill:#FEE2E2,stroke:#DC2626,color:#7F1D1D,font-weight:bold
    classDef output    fill:#152B50,stroke:#101B35,color:#FFFFFF
    classDef human     fill:#FB923C,stroke:#EA580C,color:#FFFFFF,font-weight:bold
    classDef test      fill:#F1F5F9,stroke:#94A3B8,color:#334155
    classDef decision  fill:#FFFFFF,stroke:#CBD5E1,color:#101B35

    %% ── INPUT LAYER ─────────────────────────────────────────────────────────
    subgraph INPUT["📥 Input Layer"]
        direction LR
        NL(["💬 Natural Language<br/>Task Description"]):::input
        FORM(["📝 Manual Form Input<br/>Streamlit Widgets"]):::input
    end

    %% ── NL PARSING ──────────────────────────────────────────────────────────
    PARSE["🤖 NL Parser<br/>(claude-haiku-4-5)<br/>Structured tool-use call<br/>Extracts task parameters"]:::llm
    CONF{"All fields<br/>extracted?"}:::decision
    HC1(["👤 Human Checkpoint 1<br/>Clarification Prompt"]):::human

    %% ── ORCHESTRATOR ─────────────────────────────────────────────────────────
    ORCH["⚙️ Orchestrator<br/>(orchestrator.py)<br/>Routes requests & ReAct loop"]:::process

    %% ── DETERMINISTIC CORE ───────────────────────────────────────────────────
    subgraph CORE["🛡️ Deterministic Core"]
        direction TB
        RETRIEVER["🔍 Context Retriever<br/>(get_all_tasks)"]:::process
        TOOLS["🛠️ Tools Layer<br/>(tools.py)"]:::process
        SCHED["🗓️ Scheduler<br/>(generate_schedule)"]:::process
        DETECT["🔍 Conflict Detector<br/>(sweep-line algorithm)"]:::process
        PERSIST[("💾 Persistence<br/>(data/data.json)")]:::process
    end

    %% ── LLM RESOLUTION LOOP ──────────────────────────────────────────────────
    CDET{"Conflicts<br/>detected?"}:::decision

    subgraph RLOOP["🔄 LLM Resolution Loop"]
        REACT["🧠 ReAct Agent<br/>(claude-sonnet-4-6)<br/>Thought → Action → Observation"]:::llm
        LEND{"Resolved or<br/>budget exhausted?"}:::decision
    end

    HC2(["⚠️ Human Checkpoint 2<br/>Conflict Escalation"]):::human

    %% ── GUARDRAIL ────────────────────────────────────────────────────────────
    subgraph GSUB["⚖️ Guardrail & Evaluation"]
        GVAL["🛡️ Evaluator<br/>(validate_required_tasks)"]:::guardrail
        GCHECK{"Required tasks<br/>all present?"}:::decision
        GREST["♻️ Auto-restore<br/>Dropped required tasks"]:::guardrail
    end

    %% ── OUTPUT LAYER ─────────────────────────────────────────────────────────
    subgraph OUT["📱 Output Layer"]
        UI["🖥️ Streamlit UI<br/>Gantt Chart & Agent Trace"]:::output
        HC3(["✅ Human Checkpoint 3<br/>Review & Complete"]):::human
    end

    %% ── TESTING & OBSERVABILITY ──────────────────────────────────────────────
    subgraph OBS["📊 Observability & Testing"]
        UNIT["🧪 Tester<br/>(Unit & Integration)"]:::test
        GLOG["📜 Violation Log<br/>(Audit trail)"]:::test
        ATRACE["📈 agent_trace[]<br/>Reasoning log"]:::test
    end

    %% ── DATA FLOW ────────────────────────────────────────────────────────────
    NL   --> PARSE
    FORM --> ORCH

    PARSE --> CONF
    CONF -- "Missing fields" --> HC1
    HC1  -- "Clarify" --> PARSE
    CONF -- "Validated" --> ORCH

    ORCH  --> RETRIEVER
    RETRIEVER --> TOOLS
    TOOLS --> SCHED
    SCHED --> DETECT
    DETECT --> CDET

    CDET -- "Clean" --> GVAL
    CDET -- "Conflicts" --> REACT

    REACT -- "Tool Call" --> TOOLS
    REACT --> LEND
    LEND -- "Resolved" --> GVAL
    LEND -- "Next step" --> REACT
    LEND -- "Exhausted" --> HC2

    GVAL  --> GCHECK
    GCHECK -- "Pass" --> PERSIST
    GCHECK -- "Violation" --> GREST
    GREST --> GLOG
    GREST --> PERSIST

    PERSIST --> UI
    UI  --> HC3
    HC3 -- "Update" --> TOOLS

    ORCH   --> ATRACE
    ATRACE --> UI

    UNIT -.->|validates| SCHED
    UNIT -.->|validates| DETECT
    GLOG -.->|audit| GSUB


