graph TB
    subgraph UI["UI Layer (Streamlit)"]
        CHAT["Chat Assistant\n(NL input)"]
        GANTT["Gantt Chart\n(schedule view)"]
        SIDEBAR["Sidebar\n(pet / task admin)"]
    end

    subgraph AGENT["Agent Layer"]
        ORCH["Orchestrator\n(coordinates all LLM calls)"]
        PARSER["NL Parser\nClaude Haiku 4.5\n(text to structured task)"]
        REACT["ReAct Loop\nClaude Sonnet 4.6\n(conflict resolution, up to 5 steps)"]
        GUARD["Guardrail\n(post-loop validator)"]
        TOOLS["Tool Registry\n(10 callable tools)"]
    end

    subgraph CORE["Core Scheduling Layer"]
        SCHED["Scheduler\n(two-phase deterministic)"]
        CONFLICT["Conflict Detector\n(sweep-line algorithm)"]
    end

    subgraph DATA["Data Layer"]
        OWNER["Owner"]
        PET["Pet"]
        TASK["Task"]
        RESULT["ScheduleResult"]
    end

    subgraph AUDIT["Audit & Observability"]
        TRACE["TraceStep Log\n(Thought - Action - Observation)"]
        JSONL["Guardrail JSONL\n(append-only violation log)"]
        METRICS["RunMetrics\n(latency, token usage)"]
    end

    CHAT -->|free-form text| ORCH
    SIDEBAR -->|structured form data| ORCH
    ORCH --> PARSER
    ORCH --> REACT
    ORCH --> GUARD
    REACT --> TOOLS
    TOOLS --> CONFLICT
    TOOLS --> SCHED
    SCHED --> CONFLICT
    SCHED --> RESULT
    RESULT --> GANTT
    GUARD --> JSONL
    REACT --> TRACE
    ORCH --> METRICS
    OWNER --> PET --> TASK
    SCHED --> OWNER
