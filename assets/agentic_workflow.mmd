sequenceDiagram
    actor User as 👤 Owner
    participant UI as 🖥️ Streamlit UI<br/>(app.py)
    participant Orch as ⚙️ Orchestrator<br/>(orchestrator.py)
    participant LLM as 🧠 LLM Agent<br/>(Claude API)
    participant Tools as 🛠️ Tools<br/>(tools.py)
    participant Guard as ⚖️ Guardrail<br/>(guardrail.py)

    %%─────────────────────────────────────────────────────────────────
    %% PHASE 1 — Natural Language Input Parsing
    %%─────────────────────────────────────────────────────────────────
    rect rgb(240, 244, 255)
        Note over User,Guard: Phase 1 — Natural Language Input Parsing (claude-haiku-4-5)

        User->>UI: Natural-language task description<br/>"Buddy needs a 30-min walk at 8 AM"
        UI->>Orch: parse_nl_task(raw_text)
        Orch->>LLM: system_prompt [cached] + raw_text

        alt Success
            LLM-->>Orch: tool_use → add_task(TaskDict)
            Orch->>Tools: add_task(pet_name, TaskDict)
            Tools-->>Orch: { success: true }
        else Ambiguous Input
            LLM-->>UI: clarification_request(missing_fields[])
            UI-->>User: Prompt for missing details
            User->>UI: Provides details
        end
    end

    %%─────────────────────────────────────────────────────────────────
    %% PHASE 2 — Deterministic Schedule Generation
    %%─────────────────────────────────────────────────────────────────
    rect rgb(230, 250, 245)
        Note over User,Guard: Phase 2 — Deterministic Schedule Generation

        Orch->>Tools: generate_schedule()
        Note over Tools: Phase 1: Required tasks (unconditional)<br/>Phase 2: Optional tasks (Priority DESC)
        Tools-->>Orch: ScheduleResult + Conflict Warnings
    end

    %%─────────────────────────────────────────────────────────────────
    %% PHASE 3 — LLM Resolution Loop
    %%─────────────────────────────────────────────────────────────────
    rect rgb(255, 245, 230)
        Note over User,Guard: Phase 3 — LLM-Driven Resolution Loop (claude-sonnet-4-6)

        Orch->>Tools: detect_conflicts()
        Tools-->>Orch: conflict_pairs[]

        loop Resolution Loop [max 5 steps]
            Orch->>LLM: Thought prompt + conflicts
            Note right of LLM: ReAct Protocol:<br/>Thought → Action → Observation
            LLM-->>Orch: Action: reschedule_task()
            Orch->>Tools: reschedule_task()
            Tools-->>Orch: { success: true }
            Orch->>Tools: detect_conflicts()
            Tools-->>Orch: Observation: remaining_conflicts
        end
    end

    %%─────────────────────────────────────────────────────────────────
    %% PHASE 4 — Guardrail Check
    %%─────────────────────────────────────────────────────────────────
    rect rgb(255, 235, 235)
        Note over User,Guard: Phase 4 — Guardrail Check (Safety Layer)

        Orch->>Guard: validate_required_tasks()
        alt Violation Found
            Note over Guard: Dropped required task detected
            Guard->>Tools: restore_task()
            Guard-->>Orch: { violations: [...], corrected: True }
            Orch-->>UI: Show Guardrail Alert
        else Clean
            Guard-->>Orch: { violations: [], corrected: False }
        end
    end

    %%─────────────────────────────────────────────────────────────────
    %% PHASE 5 — Persist and Render
    %%─────────────────────────────────────────────────────────────────
    rect rgb(245, 240, 255)
        Note over User,Guard: Phase 5 — Persist and Render

        Orch->>Tools: save_state()
        Orch-->>UI: { final_schedule, agent_trace[] }
        UI-->>User: Render Dashboard, Gantt Chart, and Reasoning Trace
    end
